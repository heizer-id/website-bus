{
  "version": 3,
  "overrides": {},
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/builds/meta/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=1, immutable"
      },
      "src": "/_nuxt/builds/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_fonts/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/(.*)"
    },
    {
      "src": "/_nuxt/builds/meta(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt/builds(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_fonts(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "(?<__isr_route>/__nuxt_error)",
      "dest": "/__fallback"
    },
    {
      "src": "/user",
      "dest": "/user"
    },
    {
      "src": "/seat-selection",
      "dest": "/seat-selection"
    },
    {
      "src": "/search-results",
      "dest": "/search-results"
    },
    {
      "src": "/register",
      "dest": "/register"
    },
    {
      "src": "/payment-success",
      "dest": "/payment-success"
    },
    {
      "src": "/login",
      "dest": "/login"
    },
    {
      "src": "/checkout",
      "dest": "/checkout"
    },
    {
      "src": "/cek-booking",
      "dest": "/cek-booking"
    },
    {
      "src": "/api/user/transactions",
      "dest": "/api/user/transactions"
    },
    {
      "src": "/api/seats.lock",
      "dest": "/api/seats.lock"
    },
    {
      "src": "/api/seats",
      "dest": "/api/seats"
    },
    {
      "src": "/api/schedules",
      "dest": "/api/schedules"
    },
    {
      "src": "/api/payment/doku-invoice",
      "dest": "/api/payment/doku-invoice"
    },
    {
      "src": "/api/payment/doku-callback",
      "dest": "/api/payment/doku-callback"
    },
    {
      "src": "/api/auth/register",
      "dest": "/api/auth/register"
    },
    {
      "src": "/api/auth/me",
      "dest": "/api/auth/me"
    },
    {
      "src": "/api/auth/logout",
      "dest": "/api/auth/logout"
    },
    {
      "src": "/api/auth/login",
      "dest": "/api/auth/login"
    },
    {
      "src": "/api/admin/transactions",
      "dest": "/api/admin/transactions"
    },
    {
      "src": "/api/admin/schedules",
      "dest": "/api/admin/schedules"
    },
    {
      "src": "/api/admin/buses",
      "dest": "/api/admin/buses"
    },
    {
      "src": "/admin/transactions",
      "dest": "/admin/transactions"
    },
    {
      "src": "/admin/schedules",
      "dest": "/admin/schedules"
    },
    {
      "src": "/admin/buses",
      "dest": "/admin/buses"
    },
    {
      "src": "/admin",
      "dest": "/admin"
    },
    {
      "src": "/__nuxt_error",
      "dest": "/__nuxt_error"
    },
    {
      "src": "/",
      "dest": "/index"
    },
    {
      "src": "/api/booking/(?<code>[^/]+)",
      "dest": "/api/booking/[code]"
    },
    {
      "src": "/api/_nuxt_icon/(?<collection>[^/]+)",
      "dest": "/api/_nuxt_icon/[collection]"
    },
    {
      "src": "/__nuxt_island/(?:.*)",
      "dest": "/__nuxt_island/[...]"
    },
    {
      "src": "/(.*)",
      "dest": "/__fallback"
    }
  ]
}