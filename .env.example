# Cloudflare D1 REST API Credentials
# Diperlukan agar server API bisa query D1 database dari Vercel

# Account ID Cloudflare kamu
CLOUDFLARE_ACCOUNT_ID=abbe30519ec95afcd9ea3ba6aea93509

# Database ID D1
CLOUDFLARE_D1_DATABASE_ID=141f777c-4e81-4226-a9be-8356fd3ee8d4

# API Token Cloudflare (dari https://dash.cloudflare.com/profile/api-tokens)
# Butuh permission: D1:Edit atau D1:Read
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# JWT Secret untuk auth (ganti dengan string random yang kuat)
JWT_SECRET=nusantara-secret-key-1234567890
